<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Class Library olarak ayarlanıyor -->
    <TargetFramework>net8.0</TargetFramework>
    <OutputType>Library</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- NuGet Metadata -->
    <PackageId>ACY.FluentValidationLibrary</PackageId>
    <Version>1.0.0</Version>
    <Authors>Ali Can Yücel</Authors>
    <Company>ACY Ecosystem</Company>
    <Description>Custom fluent validation library for .NET applications, built from scratch under the ACY ecosystem.</Description>
    <PackageTags>Validation;Fluent;ACY;NuGet;Library</PackageTags>
    <RepositoryUrl>https://github.com/alicanyucel/ACY.FluentValidationLibrary</RepositoryUrl>
    <PackageProjectUrl>https://github.com/alicanyucel/ACY.FluentValidationLibrary</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
  </PropertyGroup>

</Project>